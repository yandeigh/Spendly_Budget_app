<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello, User"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvStreakBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 1 Day Streak"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            android:background="#2C2C2C"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Budget Progress"
            android:textColor="#000000"
            android:layout_marginTop="16dp"/>

        <ProgressBar
            android:id="@+id/pbMonthlyBudget"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#000000"
            android:progressBackgroundTint="#000000"/>

        <TextView
            android:id="@+id/tvBudgetText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R0 / R0"
            android:textColor="#000000"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvGoalRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Add Expense"
                android:textColor="#000000"
                android:backgroundTint="#FFFFFF"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnCategories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Categories"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C2C2C"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnReports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Reports"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C2C2C"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnGoals"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Budget Goals"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C2C2C"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btnAchievements"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_columnSpan="2"
                android:text="🏆 Achievements"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C2C2C"
                android:layout_margin="4dp"/>
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Expenses"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="#888888"
            android:backgroundTint="#000000"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>